---
import ExternalLinkIcon from '../../assets/icons/external-link.svg';

type Project = {
  name: string;
  url: string;
  stars: number;
  featured: boolean;
  tagline: string;
  tech: string[];
};

type Props = {
  projects: Project[];
  githubProfileLink: string;
};

const { projects, githubProfileLink } = Astro.props;

const featured = projects.filter((p) => p.featured);
const more = projects.filter((p) => !p.featured);
---

<section id="projects" class="py-14 md:py-20">
  <div class="container">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
      <h2 class="text-foreground">Selected work</h2>
      <a
        href={githubProfileLink}
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline text-sm inline-flex items-center gap-2"
      >
        View GitHub profile
        <ExternalLinkIcon class="w-4 h-4" />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {
        featured.map((project) => (
          <article class="card card-lift group">
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="block p-6">
              <h3 class="font-display font-semibold text-xl text-foreground mb-2 group-hover:text-accent transition-colors">
                {project.name}
              </h3>
              <p class="text-foreground-secondary mb-4">{project.tagline}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.tech.map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
              {project.stars > 0 && (
                <span class="font-mono text-xs text-foreground-tertiary">
                  {project.stars} {project.stars === 1 ? 'star' : 'stars'}
                </span>
              )}
            </a>
          </article>
        ))
      }
    </div>

    {
      more.length > 0 && (
        <div class="mt-6 border-t border-line">
          {more.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-baseline justify-between gap-4 py-4 border-b border-line group"
            >
              <span class="font-medium text-foreground group-hover:text-accent-text transition-colors">
                {project.name}
              </span>
              <span class="hidden sm:block flex-1 text-sm text-foreground-tertiary truncate">
                {project.tagline}
              </span>
              {project.stars > 0 && (
                <span class="font-mono text-xs text-foreground-tertiary shrink-0">
                  {project.stars} ★
                </span>
              )}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
