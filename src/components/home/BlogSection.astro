---
import type { CollectionEntry } from 'astro:content';
import { readingTime } from '../../lib/reading-time';

import ArrowRightIcon from '../../assets/icons/arrow-right.svg';

type Props = {
  latestPosts: CollectionEntry<'posts'>[];
};

const { latestPosts } = Astro.props;
const [lead, ...rest] = latestPosts;

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<section id="writing" class="py-14 md:py-20 bg-background-subtle">
  <div class="container">
    <div class="flex items-end justify-between gap-4 mb-8">
      <h2 class="text-foreground">Writing</h2>
      <a href="/blog" class="link-underline text-sm inline-flex items-center gap-2">
        Read all
        <ArrowRightIcon class="w-4 h-4" />
      </a>
    </div>

    {
      lead && (
        <a href={`/blog/${lead.id}`} class="block group mb-8 max-w-prose">
          <h3 class="font-display font-semibold text-2xl text-foreground mb-3 group-hover:text-accent transition-colors">
            {lead.data.title}
          </h3>
          <p class="text-foreground-secondary mb-3">{lead.data.description}</p>
          <div class="flex items-center gap-3 font-mono text-xs text-foreground-tertiary">
            <span>
              {fmt(lead.data.pubDate)} · {readingTime(lead.body ?? '')} min read
            </span>
            {lead.data.tags[0] && <span class="topic">{lead.data.tags[0]}</span>}
          </div>
        </a>
      )
    }

    {
      rest.length > 0 && (
        <div class="border-t border-line max-w-prose">
          {rest.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="flex items-baseline gap-4 py-4 border-b border-line group"
            >
              <time class="font-mono text-xs text-foreground-tertiary w-24 shrink-0">
                {fmt(post.data.pubDate)}
              </time>
              <span class="font-display font-semibold text-foreground group-hover:text-accent transition-colors">
                {post.data.title}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
