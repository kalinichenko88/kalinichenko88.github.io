---
import { getCollection, render } from 'astro:content';

import Layout from '../../components/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

import ArrowLeftIcon from '../../assets/icons/arrow-left.svg';
import ClockIcon from '../../assets/icons/clock.svg';
import TwitterIcon from '../../assets/icons/twitter.svg';
import LinkedInIcon from '../../assets/icons/linkedin.svg';

import {
  AUTHOR_NAME,
  SITE_TITLE,
  GISCUS_REPO,
  GISCUS_REPO_ID,
  GISCUS_CATEGORY,
  GISCUS_CATEGORY_ID,
} from '../../consts';

const giscusConfig = JSON.stringify({
  repo: GISCUS_REPO,
  repoId: GISCUS_REPO_ID,
  category: GISCUS_CATEGORY,
  categoryId: GISCUS_CATEGORY_ID,
});

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

// Calculate reading time (rough estimate)
const wordsPerMinute = 200;
const wordCount = post.body?.split(/\s+/).filter(Boolean).length || 0;
const readingTime = Math.ceil(wordCount / wordsPerMinute);

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: 'https://kalinichenko.dev',
  },
  publisher: {
    '@type': 'Person',
    name: AUTHOR_NAME,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
  keywords: post.data.tags.join(', '),
};
---

<Layout
  title={`${post.data.title} – ${SITE_TITLE}`}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  tags={post.data.tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />
  <article class="py-12 md:py-16">
    <div class="container">
      <!-- Article Header -->
      <header class="mb-8">
        <!-- Back Link -->
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm text-foreground-tertiary hover:text-foreground transition-colors mb-6"
        >
          <ArrowLeftIcon class="w-4 h-4" />
          Back to all posts
        </a>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-4">
          {
            post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">
                {tag}
              </a>
            ))
          }
        </div>

        <!-- Title -->
        <h1 class="text-foreground mb-4">
          {post.data.title}
        </h1>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-foreground-tertiary font-mono">
          <time datetime={post.data.pubDate.toISOString()}>
            {
              post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })
            }
          </time>
          <span class="flex items-center gap-2">
            <ClockIcon class="w-4 h-4" />
            {readingTime} min read
          </span>
        </div>
      </header>

      {
        tocHeadings.length > 0 && (
          <div id="toc-inline" class="mb-10">
            <TableOfContents headings={headings} />
          </div>
        )
      }

      <div class:list={[{ 'article-with-toc': tocHeadings.length > 0 }]}>
        <div class="prose prose-lg prose-custom max-w-none">
          <Content />
        </div>

        {
          tocHeadings.length > 0 && (
            <aside class="toc-sidebar-col" aria-hidden="true">
              <div class="toc-sidebar-sticky" id="toc-sidebar">
                <TableOfContents headings={headings} label="Table of contents (sidebar)" />
              </div>
            </aside>
          )
        }
      </div>

      <!-- Comments -->
      <section class="mt-12 pt-8 border-t border-line">
        <h2 class="text-xl font-display font-semibold text-foreground mb-6">Comments</h2>
        <div class="giscus"></div>
        <script is:inline data-giscus-config={giscusConfig}>
          (function () {
            const config = JSON.parse(document.currentScript.dataset.giscusConfig);
            const giscusThemes = {
              cloud: 'light',
              'cloud-dark': 'transparent_dark',
              terminal: 'dark',
            };

            function getGiscusTheme() {
              const theme = document.documentElement.getAttribute('data-theme') || 'cloud';
              return giscusThemes[theme] || 'light';
            }

            function loadGiscus() {
              const container = document.querySelector('.giscus');
              if (!container) return;
              container.innerHTML = '';

              const script = document.createElement('script');
              script.src = 'https://giscus.app/client.js';
              script.setAttribute('data-repo', config.repo);
              script.setAttribute('data-repo-id', config.repoId);
              script.setAttribute('data-category', config.category);
              script.setAttribute('data-category-id', config.categoryId);
              script.setAttribute('data-mapping', 'pathname');
              script.setAttribute('data-strict', '0');
              script.setAttribute('data-reactions-enabled', '1');
              script.setAttribute('data-emit-metadata', '0');
              script.setAttribute('data-input-position', 'top');
              script.setAttribute('data-theme', getGiscusTheme());
              script.setAttribute('data-lang', 'en');
              script.setAttribute('data-loading', 'lazy');
              script.crossOrigin = 'anonymous';
              script.async = true;
              container.appendChild(script);
            }

            // Prevent duplicate listeners across View Transitions
            if (!window.__giscusInitialized) {
              window.__giscusInitialized = true;
              window.addEventListener('theme-changed', loadGiscus);
              document.addEventListener('astro:after-swap', loadGiscus);
            }

            loadGiscus();
          })();
        </script>
      </section>

      <!-- Article Footer -->
      <footer class="mt-10 pt-6 border-t border-line">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium text-foreground-secondary hover:text-foreground transition-colors"
          >
            <ArrowLeftIcon class="w-4 h-4" />
            All posts
          </a>

          <div class="flex items-center gap-4">
            <span class="text-sm text-foreground-tertiary">Share:</span>
            <a
              href={`https://x.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 text-foreground-tertiary hover:text-foreground transition-colors"
              aria-label="Share on Twitter"
            >
              <TwitterIcon class="w-4 h-4" />
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 text-foreground-tertiary hover:text-foreground transition-colors"
              aria-label="Share on LinkedIn"
            >
              <LinkedInIcon class="w-4 h-4" />
            </a>
          </div>
        </div>
      </footer>
    </div>
  </article>

  <script>
    let sidebarObserverRef: IntersectionObserver | null = null;
    let headingObserverRef: IntersectionObserver | null = null;

    function initTocObserver() {
      // Disconnect previous observers to prevent leaks across View Transitions
      sidebarObserverRef?.disconnect();
      headingObserverRef?.disconnect();
      sidebarObserverRef = null;
      headingObserverRef = null;

      const inlineToc = document.getElementById('toc-inline');
      const sidebar = document.getElementById('toc-sidebar');
      if (!inlineToc || !sidebar) return;

      const sidebarCol = sidebar.closest('.toc-sidebar-col');

      sidebarObserverRef = new IntersectionObserver(
        ([entry]) => {
          const isVisible = !entry.isIntersecting;
          sidebar.classList.toggle('visible', isVisible);
          // Toggle focusability of sidebar links for keyboard accessibility
          sidebar.querySelectorAll('a').forEach((a) => {
            a.tabIndex = isVisible ? 0 : -1;
          });
          sidebarCol?.setAttribute('aria-hidden', String(!isVisible));
        },
        { threshold: 0 }
      );
      sidebarObserverRef.observe(inlineToc);

      // Ensure sidebar links start as unfocusable
      sidebar.querySelectorAll('a').forEach((a) => {
        a.tabIndex = -1;
      });

      // Active heading tracking
      const tocLinks = document.querySelectorAll('.toc-link');
      const headings = Array.from(
        document.querySelectorAll('.prose h2[id], .prose h3[id]')
      ) as HTMLElement[];
      if (!headings.length) return;

      let currentActiveId = '';
      headingObserverRef = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              currentActiveId = entry.target.id;
            }
          }
          tocLinks.forEach((link) => {
            link.classList.toggle('active', link.getAttribute('href') === `#${currentActiveId}`);
          });
        },
        { rootMargin: '0px 0px -70% 0px', threshold: 0 }
      );

      headings.forEach((h) => headingObserverRef!.observe(h));
    }

    initTocObserver();
    document.addEventListener('astro:after-swap', initTocObserver);
  </script>

  <style>
    .article-with-toc {
      position: relative;
    }

    .toc-sidebar-col {
      display: none;
    }

    @media (min-width: 1280px) {
      .article-with-toc {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: var(--space-12);
      }

      .toc-sidebar-col {
        display: block;
      }
    }

    .toc-sidebar-sticky {
      position: sticky;
      top: var(--space-24);
      opacity: 0;
      transform: translateX(1rem);
      transition:
        opacity var(--transition-slow),
        transform var(--transition-slow);
      pointer-events: none;
    }

    .toc-sidebar-sticky.visible {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
    }
  </style>
</Layout>
