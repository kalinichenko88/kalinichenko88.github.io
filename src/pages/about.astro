---
import Layout from '../components/Layout.astro';
import ExpertiseGrid from '../components/home/ExpertiseGrid.astro';

import { MAIL_PROFILE_LINK, LINKEDIN_PROFILE_LINK } from '../consts';
import { WORK_HISTORY, EXPERTISE, LOCATION } from '../config/resume';
---

<Layout
  title="About"
  description="About Ivan Kalinichenko — AI agent systems and full-stack engineering."
>
  <section class="py-14 md:py-20">
    <div class="container-prose">
      <h1 class="text-foreground mb-6">About</h1>
      <div class="space-y-4 text-foreground-secondary text-lg leading-relaxed">
        <p>
          I design and build production systems around AI agents and the infrastructure they run
          on. My focus includes agent runtimes, MCP servers, long-term memory layers, model routing
          and failover, agent development pipelines, and Telegram and Discord integrations.
        </p>
        <p>
          I bring 15+ years in frontend and full-stack engineering, from jQuery and AngularJS to
          modern React and TypeScript. That path shaped how I think about maintainable systems and
          team productivity.
        </p>
        <p>
          Alongside agent systems, I work on 0→1 full-stack products and frontend modernization:
          legacy migrations, design systems, component libraries, testing, and build infrastructure.
        </p>
        <p>
          Today I build the frontend for a large-scale self-hosted product. I also review merge
          requests, mentor frontend developers, run technical interviews, and onboard new engineers.
        </p>
        <p>
          Based in <span class="text-foreground">{LOCATION}</span>, working with international
          remote teams.
        </p>
      </div>

      <div class="flex flex-wrap gap-3 mt-8">
        <a href={`mailto:${MAIL_PROFILE_LINK}`} class="btn-primary">Get in touch</a>
        <a
          href={LINKEDIN_PROFILE_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-background-subtle">
    <div class="container">
      <h2 class="text-foreground mb-8">Expertise</h2>
      <ExpertiseGrid expertise={EXPERTISE} />
    </div>
  </section>

  <section class="py-14 md:py-20">
    <div class="container-prose">
      <h2 class="text-foreground mb-8">Work history</h2>
      <div class="space-y-6">
        {
          WORK_HISTORY.map((job) => (
            <div class="flex items-baseline justify-between gap-4 border-b border-line pb-4">
              <div>
                <div class="font-medium text-foreground">{job.company}</div>
                <div class="text-sm text-foreground-secondary">{job.title}</div>
              </div>
              <span class="font-mono text-xs text-foreground-tertiary shrink-0">{job.period}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
