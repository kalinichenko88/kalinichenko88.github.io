---
import Layout from '../components/Layout.astro';
import ExpertiseGrid from '../components/home/ExpertiseGrid.astro';

import { MAIL_PROFILE_LINK, LINKEDIN_PROFILE_LINK } from '../consts';
import { WORK_HISTORY, EXPERTISE, LOCATION } from '../config/resume';
---

<Layout
  title="About"
  description="About Ivan Kalinichenko — AI systems engineer and full-stack product developer."
>
  <section class="py-14 md:py-20">
    <div class="container-prose">
      <h1 class="text-foreground mb-6">About</h1>
      <div class="space-y-4 text-foreground-secondary text-lg leading-relaxed">
        <p>
          I'm an AI systems engineer with 15+ years in software development. I design and build
          production systems around AI agents: multi-agent runtimes, MCP servers, long-term memory
          layers, model routing and failover, and integrations for Telegram and Discord.
        </p>
        <p>
          I also take products from 0→1 across the stack—backend, frontend, billing, email, privacy,
          infrastructure, and documentation—and modernize complex frontend platforms without
          pausing product delivery.
        </p>
        <p>
          In my current role, I build the frontend for a large-scale self-hosted product with React
          and TypeScript. I also review merge requests, mentor frontend developers, run technical
          interviews, and onboard new engineers.
        </p>
        <p>
          Based in <span class="text-foreground">{LOCATION}</span>, working with international
          remote teams.
        </p>
      </div>

      <div class="flex flex-wrap gap-3 mt-8">
        <a href={`mailto:${MAIL_PROFILE_LINK}`} class="btn-primary">Discuss a project</a>
        <a
          href={LINKEDIN_PROFILE_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-background-subtle">
    <div class="container">
      <h2 class="text-foreground mb-8">Expertise</h2>
      <ExpertiseGrid expertise={EXPERTISE} />
    </div>
  </section>

  <section class="py-14 md:py-20">
    <div class="container-prose">
      <h2 class="text-foreground mb-8">Work history</h2>
      <div class="space-y-6">
        {
          WORK_HISTORY.map((job) => (
            <div class="flex items-baseline justify-between gap-4 border-b border-line pb-4">
              <div>
                <div class="font-medium text-foreground">{job.company}</div>
                <div class="text-sm text-foreground-secondary">{job.title}</div>
              </div>
              <span class="font-mono text-xs text-foreground-tertiary shrink-0">{job.period}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
